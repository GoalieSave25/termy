{
  "name": "termy",
  "productName": "Termy",
  "version": "0.1.0",
  "description": "tmux on steroids with a good UI",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "postinstall": "bash scripts/patch-dev-icon.sh",
    "start": "electron-forge start",
    "generate-icon": "node scripts/generate-icon.js",
    "package": "npm run generate-icon && electron-forge package",
    "make": "npm run generate-icon && electron-forge make",
    "publish": "npm run generate-icon && electron-forge publish",
    "setup": "bash scripts/install.sh",
    "lint": "eslint --ext .ts,.tsx .",
    "start:packaged": "npm run package && open out/Termy-darwin-arm64/Termy.app"
  },
  "keywords": [],
  "author": {
    "name": "Mathew",
    "email": "goaliesave25@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "electron": "40.7.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "immer": "^11.1.4",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.7.0",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "allotment": "^1.20.5",
    "electron-squirrel-startup": "^1.0.1",
    "ghostty-web": "^0.4.0",
    "nanoid": "^5.1.6",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  }
}
